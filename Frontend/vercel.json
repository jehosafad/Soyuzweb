{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://soyuzweb.onrender.com/api/:path*"
    },
    {
      "source": "/ping",
      "destination": "https://soyuzweb.onrender.com/ping"
    }
  ]
}