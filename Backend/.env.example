NODE_ENV=development
PORT=4000

# CORS (lista separada por comas)
CORS_ORIGINS=http://localhost:5173

# Compatibilidad (si no defines CORS_ORIGINS, se usa FRONTEND_ORIGIN)
FRONTEND_ORIGIN=http://localhost:5173

# Límite de JSON
BODY_LIMIT=10kb

# Rate limit API (burst + ventana)
RATE_LIMIT_API_BURST_WINDOW_MS=60000
RATE_LIMIT_API_BURST_LIMIT=60
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_LIMIT=300

# Rate limit Contacto (burst + ventana)
RATE_LIMIT_CONTACT_BURST_WINDOW_MS=60000
RATE_LIMIT_CONTACT_BURST_LIMIT=5
RATE_LIMIT_CONTACT_WINDOW_MS=600000
RATE_LIMIT_CONTACT_LIMIT=20

# Timeouts server (ms)
SERVER_REQUEST_TIMEOUT_MS=15000
SERVER_HEADERS_TIMEOUT_MS=20000
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000

# DB
DB_HOST=localhost
DB_PORT=5432
DB_USER=soyuz_user
DB_PASSWORD=290106
DB_NAME=soyuz_db

# DATABASE_URL (migraciones)
DATABASE_URL=postgres://soyuz_user:290106@localhost:5432/soyuz_db

# Anti-spam /api/contact
CONTACT_DEDUPE_WINDOW_SEC=600
CONTACT_EMAIL_WINDOW_SEC=600
CONTACT_MAX_PER_EMAIL_WINDOW=3
CONTACT_MAX_URLS=2

JWT_SECRET=CAMBIA_ESTA_LLAVE_POR_UNA_DE_AL_MENOS_32_CARACTERES
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=12

ADMIN_EMAIL=admin@soyuz.local
ADMIN_PASSWORD=AdminDocker12345!
ADMIN_ROLE=admin