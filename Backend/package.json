{
  "name": "soyuz-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "seed:admin": "node src/scripts/seedAdmin.js",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate:up": "node-pg-migrate up --config pgmigrate.config.js",
    "migrate:down": "node-pg-migrate down --config pgmigrate.config.js",
    "migrate:create": "node-pg-migrate create --config pgmigrate.config.js",
    "test:prepare": "cross-env NODE_ENV=test DATABASE_URL=postgres://soyuz_user:290106@localhost:5432/soyuz_test_db node-pg-migrate up --config pgmigrate.config.js",
    "test": "npm run test:prepare && cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watchAll",
    "lint": "eslint .",
    "docker:up": "docker compose --env-file .env.docker up --build -d",
    "docker:down": "docker compose --env-file .env.docker down",
    "docker:logs": "docker compose --env-file .env.docker logs -f api db"
  },
